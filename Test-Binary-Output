def main():  # should only expect to get about 75% maximum accuracy
    schedulerPatience = [10, 30, 40, 50]
    schedulerFactor = [0.5, 0.65, 0.75]
    lr = [1e-6, 1e-5, 5e-5, 1e-4, 3e-4]
    early_stop_patience = [40, 70]
    shuffleTrain_options = [True, False]

    results = []

    for sp, sf, learning_rate, esp, shuffleTrain in product(
        schedulerPatience,
        schedulerFactor,
        lr,
        early_stop_patience,
        shuffleTrain_options
    ):

        # Generate unique log filename
        base_name = "training_log"
        ext = ".txt"
        i = 1
        filename = f"{base_name}{ext}"

        while os.path.exists(filename):
            i += 1
            filename = f"{base_name}{i}{ext}"

        log_file = open(filename, "w")
        old_stdout = sys.stdout
        sys.stdout = log_file

        print('sp:', sp,
              'sf:', sf,
              'lr:', learning_rate,
              'early_stop_patience:', esp,
              'shuffleTrain:', shuffleTrain)

        accuracy = trueMain(
            sp,
            sf,
            learning_rate,
            esp,
            shuffleTrain
        )

        # restore console output
        sys.stdout = old_stdout
        log_file.close()

        # store experiment result
        results.append({
            "schedulerPatience": sp,
            "schedulerFactor": sf,
            "lr": learning_rate,
            "early_stop_patience": esp,
            "shuffleTrain": shuffleTrain,
            "accuracy": accuracy
        })
    # Convert results to DataFrame
    df = pd.DataFrame(results)
    print("\nAll experiment results:")
    print(df)
    # Sort by best accuracy
    df_sorted = df.sort_values(by="accuracy", ascending=False)
    print("\nBest hyperparameters:")
    print(df_sorted.iloc[0])
    # Optional: save results
    df_sorted.to_csv("hyperparameter_results.csv", index=False)
    return df_sorted


if __name__ == "__main__":
    multiprocessing.freeze_support()
    main()
